precocombustivel = float(input("Digite o preço do litro do combustível(R$):"))
desempenho = float(input("Digite o desempenho do veículo(Km/l): "))
distancia = float(input("Digite a distancia entre as cidades (KM): "))

litros = distancia / desempenho
custototal = litros * precocombustivel

print("Para percorrer", distancia, "km: ")
print(f"Você vai gastar {litros:.2f} litros de combustível.")
print(f"O custo total da viagem será de R$: {custototal:.2f}")